{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velo",
  "mainBinaryName": "velo",
  "identifier": "com.velo.app",
  "build": {
    "beforeDevCommand": "pnpm -F desktop dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "pnpm -F desktop build",
    "beforeBundleCommand": "node ./src-tauri/scripts/before-bundle.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*",
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "publisher": "Velo",
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": [],
    "icon": [
      "icons/stable/32x32.png",
      "icons/stable/128x128.png",
      "icons/stable/128x128@2x.png",
      "icons/stable/icon.icns",
      "icons/stable/icon.ico"
    ],
    "resources": {
      "../../../plugins/windows/swift-lib/src/Resources/CabinSketch-Regular.ttf": "CabinSketch-Regular.ttf",
      "../../../plugins/windows/swift-lib/src/Resources/OFL.txt": "CabinSketch-OFL.txt",
      "icons/stable/icon.icns": "icons/stable.icns",
      "resources/notification-icons": "notification-icons"
    },
    "macOS": {
      "minimumSystemVersion": "14.2",
      "frameworks": [],
      "entitlements": "./Entitlements.plist",
      "dmg": {
        "background": "assets/dmg-background-stable.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 177,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 483,
          "y": 200
        }
      },
      "files": {
        "Resources/mlx-swift_Cmlx.bundle/default.metallib": "resources/mlx.metallib",
        "Resources/AppIcon.incs": "resources/stable/AppIcon.icns",
        "Resources/Assets.car": "resources/stable/Assets.car"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "velo"
        ]
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/BryanParreira/Velo/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4MDhFREJBOTc3MDIyODcKUldTSEluQ1h1dTBJdUlaV1BCYytjUC9rWDNacFNCaTJpZnQvbzdHOWpVNWZlcHZqWTZ6YkJlV2kK"
    }
  }
}
